# Anthropic API Configuration
# Get your API key from: https://console.anthropic.com/
OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=mistralai/mistral-large-2512

# Authentication
# Set to 'true' to disable auth during development (DO NOT set in production)
NEXT_PUBLIC_DISABLE_AUTH=false

# E2E only: a valid unlock pattern (comma-separated) for the prod Playwright suite.
# Keep the real value ONLY in .env.local (gitignored). Leave blank here.
TEST_AUTH_PATTERN=

# Upstash Redis (Rate Limiting)
# Previously Vercel KV — uses same env vars for backward compatibility
# KV_REST_API_URL=<your-upstash-url>
# KV_REST_API_TOKEN=<your-upstash-token>
