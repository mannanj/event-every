# Anthropic API Configuration
# Get your API key from: https://console.anthropic.com/
OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=mistralai/mistral-large-2512

# Authentication
# Set to 'true' to disable auth during development (DO NOT set in production)
NEXT_PUBLIC_DISABLE_AUTH=false

# E2E only: a valid unlock pattern (comma-separated) for the prod Playwright suite.
# Keep the real value ONLY in .env.local (gitignored). Leave blank here.
TEST_AUTH_PATTERN=

# Upstash Redis (Rate Limiting)
# Previously Vercel KV — uses same env vars for backward compatibility
# KV_REST_API_URL=<your-upstash-url>
# KV_REST_API_TOKEN=<your-upstash-token>
# Lightweight model for the 2-3 word Recent-summons card labels (fast/cheap).
# Use the dated id; the bare `mistralai/ministral-8b` alias 404s.
OPENROUTER_SUMMARY_MODEL=mistralai/ministral-8b-2512

# --- Community access ---
# Shared daily budget (USD, resets midnight UTC) for anonymous usage. Admins
# (pattern unlock) bypass it and use OPENROUTER_API_KEY.
DAILY_BUDGET_USD=5
# Optional dedicated key for community traffic; falls back to OPENROUTER_API_KEY.
# Recommended: create it with a $5 credit limit + daily reset on OpenRouter as a
# hard upstream backstop (see docs/cost-analysis.md).
# OPENROUTER_COMMUNITY_KEY=

# --- Spirit & Hammer waitlist (Cloudflare D1 over REST) ---
# CLOUDFLARE_ACCOUNT_ID=<account id>
# CLOUDFLARE_D1_DATABASE_ID=<database uuid>
# Token with Account / D1 / Edit permission (dash.cloudflare.com -> API Tokens)
# CLOUDFLARE_D1_API_TOKEN=

# --- Resend (waitlist confirmation emails) ---
# RESEND_API_KEY=
# Must use a domain verified in Resend; onboarding@resend.dev only delivers to
# the Resend account owner.
# RESEND_FROM=Spirit & Hammer <waitlist@yourdomain.com>
